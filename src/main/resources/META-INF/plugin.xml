<idea-plugin>
    <id>com.workflow.orchestrator.plugin</id>
    <name>Workflow Orchestrator</name>
    <vendor>Workflow Team</vendor>
    <description><![CDATA[
        Eliminates context-switching between Jira, Bamboo, SonarQube, Bitbucket, and Cody Enterprise
        by consolidating the entire Spring Boot development lifecycle into a single IDE interface.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends optional="true" config-file="plugin-withGit.xml">Git4Idea</depends>
<depends optional="true" config-file="plugin-withMaven.xml">org.jetbrains.idea.maven</depends>
    <depends optional="true" config-file="plugin-withSpring.xml">com.intellij.spring</depends>
    <depends optional="true" config-file="plugin-withTasks.xml">com.intellij.tasks</depends>
    <depends optional="true" config-file="plugin-withCoverage.xml">Coverage</depends>

    <resource-bundle>messages.WorkflowBundle</resource-bundle>

    <extensionPoints>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.tabProvider"
            interface="com.workflow.orchestrator.core.toolwindow.WorkflowTabProvider"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.branchNameAiGenerator"
            interface="com.workflow.orchestrator.core.ai.BranchNameAiGenerator"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.jiraTicketProvider"
            interface="com.workflow.orchestrator.core.workflow.JiraTicketProvider"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.textGenerationService"
            interface="com.workflow.orchestrator.core.ai.TextGenerationService"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.agentChatRedirect"
            interface="com.workflow.orchestrator.core.ai.AgentChatRedirect"
            dynamic="true"/>
    </extensionPoints>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Settings -->
        <projectConfigurable
            parentId="tools"
            instance="com.workflow.orchestrator.core.settings.WorkflowSettingsConfigurable"
            id="workflow.orchestrator"
            displayName="Workflow Orchestrator"
            nonDefaultProject="true"/>

        <projectConfigurable
            parentId="workflow.orchestrator"
            instance="com.workflow.orchestrator.core.settings.GeneralConfigurable"
            id="workflow.orchestrator.general"
            displayName="General"
            nonDefaultProject="true"/>

        <projectConfigurable
            parentId="workflow.orchestrator"
            instance="com.workflow.orchestrator.jira.settings.WorkflowConfigurable"
            id="workflow.orchestrator.workflow_config"
            displayName="Workflow"
            nonDefaultProject="true"/>

        <projectConfigurable
            parentId="workflow.orchestrator"
            instance="com.workflow.orchestrator.automation.settings.CiCdConfigurable"
            id="workflow.orchestrator.cicd"
            displayName="CI/CD"
            nonDefaultProject="true"/>

        <projectConfigurable
            parentId="workflow.orchestrator"
            instance="com.workflow.orchestrator.core.settings.AiAdvancedConfigurable"
            id="workflow.orchestrator.ai_advanced"
            displayName="AI &amp; Advanced"
            nonDefaultProject="true"/>

        <!-- Tool Window -->
        <toolWindow
            id="Workflow"
            anchor="bottom"
            icon="/icons/workflow.svg"
            factoryClass="com.workflow.orchestrator.core.toolwindow.WorkflowToolWindowFactory"/>

        <!-- Notification Groups -->
        <notificationGroup id="workflow.build" displayType="BALLOON"/>
        <notificationGroup id="workflow.quality" displayType="BALLOON"/>
        <notificationGroup id="workflow.queue" displayType="BALLOON"/>
        <notificationGroup id="workflow.automation" displayType="BALLOON"/>

        <!-- Project Services -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.settings.PluginSettings"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.util.DefaultBranchResolver"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.settings.RepoContextResolver"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.offline.ConnectivityMonitor"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.notifications.WorkflowNotificationService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.onboarding.OnboardingService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.events.EventBus"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.ai.AiSettings"/>

        <!-- Unified Service Layer (shared by UI panels and AI agent) -->
        <projectService
            serviceInterface="com.workflow.orchestrator.core.services.JiraService"
            serviceImplementation="com.workflow.orchestrator.jira.service.JiraServiceImpl"/>
        <projectService
            serviceInterface="com.workflow.orchestrator.core.services.BambooService"
            serviceImplementation="com.workflow.orchestrator.bamboo.service.BambooServiceImpl"/>
        <projectService
            serviceInterface="com.workflow.orchestrator.core.services.SonarService"
            serviceImplementation="com.workflow.orchestrator.sonar.service.SonarServiceImpl"/>
        <projectService
            serviceInterface="com.workflow.orchestrator.core.services.BitbucketService"
            serviceImplementation="com.workflow.orchestrator.pullrequest.service.BitbucketServiceImpl"/>

        <!-- Maven Build Service -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.maven.MavenBuildService"/>

        <!-- Health Check -->
        <vcsCheckinHandlerFactory
            implementation="com.workflow.orchestrator.core.healthcheck.HealthCheckCheckinHandlerFactory"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.healthcheck.HealthCheckService"/>
        <notificationGroup id="workflow.healthcheck" displayType="BALLOON"/>

        <!-- Jira Active Ticket -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.jira.service.ActiveTicketService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.jira.service.TicketKeyCache"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.jira.service.IssueDetailCache"/>

        <!-- Bamboo Services -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.bamboo.service.BuildMonitorService"/>

        <!-- Startup (onboarding check) -->
        <postStartupActivity
            implementation="com.workflow.orchestrator.core.onboarding.OnboardingStartupListener"/>

        <!-- TODO Phase 1B: BuildStatusBarWidgetFactory -->

        <!-- SonarQube Project Services -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.sonar.service.SonarDataService"/>
        <!-- SonarQube Editor Integration -->
        <codeInsight.lineMarkerProvider language="JAVA"
            implementationClass="com.workflow.orchestrator.sonar.ui.CoverageLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="kotlin"
            implementationClass="com.workflow.orchestrator.sonar.ui.CoverageLineMarkerProvider"/>

        <externalAnnotator language="JAVA"
            implementationClass="com.workflow.orchestrator.sonar.ui.SonarIssueAnnotator"/>
        <externalAnnotator language="kotlin"
            implementationClass="com.workflow.orchestrator.sonar.ui.SonarIssueAnnotator"/>

        <!-- Cody Intention Action (Alt+Enter) — language-filtered to Java/Kotlin only -->
        <intentionAction>
            <language>JAVA</language>
            <className>com.workflow.orchestrator.cody.editor.CodyIntentionAction</className>
            <category>Workflow Orchestrator</category>
        </intentionAction>
        <intentionAction>
            <language>kotlin</language>
            <className>com.workflow.orchestrator.cody.editor.CodyIntentionAction</className>
            <category>Workflow Orchestrator</category>
        </intentionAction>

        <!-- Cody Commit Message -->
        <vcsCheckinHandlerFactory
            implementation="com.workflow.orchestrator.cody.vcs.CodyCommitMessageHandlerFactory"/>

        <!-- Automation Module Project Services -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.automation.service.QueueService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.automation.service.TagBuilderService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.automation.service.DriftDetectorService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.automation.service.ConflictDetectorService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.automation.service.TagHistoryService"/>

        <!-- App-level (cross-project) -->
        <applicationService
            serviceImplementation="com.workflow.orchestrator.core.settings.ConnectionSettings"/>
        <applicationService
            serviceImplementation="com.workflow.orchestrator.automation.service.AutomationSettingsService"/>
        <applicationService
            serviceImplementation="com.workflow.orchestrator.agent.service.GlobalSessionIndex"/>

        <!-- Status Bar -->
        <statusBarWidgetFactory id="WorkflowAutomationStatusBar"
            implementation="com.workflow.orchestrator.automation.ui.AutomationStatusBarWidgetFactory"/>

        <!-- Startup Recovery -->
        <postStartupActivity
            implementation="com.workflow.orchestrator.automation.service.QueueRecoveryStartupActivity"/>

        <!-- Notification group for queue state changes -->
        <notificationGroup id="workflow.automation.queue" displayType="BALLOON"/>

        <!-- Phase 2B: Handover Services -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.handover.service.HandoverStateService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.handover.service.CopyrightFixService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.handover.service.PreReviewService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.bitbucket.PrService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.handover.service.JiraClosureService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.handover.service.TimeTrackingService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.handover.service.QaClipboardService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.handover.service.CompletionMacroService"/>

        <!-- Pull Request Services -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.pullrequest.service.PrListService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.pullrequest.service.PrDetailService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.pullrequest.service.PrActionService"/>

        <!-- Pull Request Notification Group -->
        <notificationGroup id="workflow.pr" displayType="BALLOON"/>

        <!-- Handover Notification Group -->
        <notificationGroup id="workflow.handover" displayType="BALLOON"/>

        <!-- Agent Module -->
        <notificationGroup id="workflow.agent" displayType="BALLOON"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.settings.AgentSettings"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.ui.AgentControllerRegistry"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.AgentService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.settings.ToolPreferences"/>
        <projectConfigurable
            parentId="workflow.orchestrator"
            instance="com.workflow.orchestrator.agent.settings.AgentSettingsConfigurable"
            id="workflow.orchestrator.agent"
            displayName="Agent"
            nonDefaultProject="true"/>
        <postStartupActivity
            implementation="com.workflow.orchestrator.agent.listeners.AgentStartupActivity"/>
        <fileEditorProvider
            implementation="com.workflow.orchestrator.agent.ui.plan.AgentPlanEditorProvider"/>
        <fileEditorProvider
            implementation="com.workflow.orchestrator.agent.ui.AgentVisualizationEditorProvider"/>

        <!-- Jira Ticket Reference TODO Pattern -->
        <todoIndexPattern pattern="\b[A-Z][A-Z0-9]+-\d+\b" caseSensitive="true"/>

        <!-- Commit Dialog: Jira Time Tracking -->
        <checkinHandlerFactory
            implementation="com.workflow.orchestrator.jira.vcs.TimeTrackingCheckinHandlerFactory"/>

        <!-- Post-Commit Jira Transition -->
        <checkinHandlerFactory
            implementation="com.workflow.orchestrator.jira.vcs.PostCommitTransitionHandlerFactory"/>

        <!-- Search Everywhere: Jira Tickets -->
        <searchEverywhereContributor
            implementation="com.workflow.orchestrator.jira.search.JiraSearchContributorFactory"/>

        <!-- Bamboo Run Configuration -->
        <configurationType implementation="com.workflow.orchestrator.bamboo.run.BambooBuildConfigurationType"/>

        <!-- Before Run: Docker Tag Validation -->
        <stepsBeforeRunProvider
            implementation="com.workflow.orchestrator.automation.run.TagValidationBeforeRunProvider"/>
    </extensions>

    <extensions defaultExtensionNs="com.workflow.orchestrator">
        <branchNameAiGenerator
            implementation="com.workflow.orchestrator.core.ai.SourcegraphBranchNameGenerator"/>
        <jiraTicketProvider
            implementation="com.workflow.orchestrator.jira.service.JiraTicketProviderImpl"/>
        <textGenerationService
            implementation="com.workflow.orchestrator.core.ai.SourcegraphTextGenerationService"/>
        <agentChatRedirect
            implementation="com.workflow.orchestrator.agent.ui.AgentChatRedirectImpl"/>
        <tabProvider implementation="com.workflow.orchestrator.jira.ui.SprintTabProvider"/>
        <tabProvider implementation="com.workflow.orchestrator.bamboo.ui.BuildTabProvider"/>
        <tabProvider implementation="com.workflow.orchestrator.sonar.ui.QualityTabProvider"/>
        <tabProvider implementation="com.workflow.orchestrator.pullrequest.ui.PrTabProvider"/>
        <tabProvider implementation="com.workflow.orchestrator.automation.ui.AutomationTabProvider"/>
        <tabProvider implementation="com.workflow.orchestrator.handover.ui.HandoverTabProvider"/>
        <tabProvider implementation="com.workflow.orchestrator.agent.ui.AgentTabProvider"/>
        <tabProvider implementation="com.workflow.orchestrator.agent.ui.HistoryTabProvider"/>
    </extensions>

    <actions>
        <action
            id="Workflow.GenerateCommitMessage"
            text="Generate with Workflow"
            description="Generate commit message using Cody AI"
            class="com.workflow.orchestrator.cody.vcs.GenerateCommitMessageAction">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="first"/>
        </action>
    </actions>
</idea-plugin>
