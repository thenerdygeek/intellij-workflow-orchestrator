<idea-plugin>
    <id>com.workflow.orchestrator.plugin</id>
    <name>Workflow Orchestrator</name>
    <vendor>Workflow Team</vendor>
    <description><![CDATA[Eliminates context-switching between Jira, Bamboo, SonarQube, Bitbucket, and AI agent
        by consolidating the entire Spring Boot development lifecycle into a single IDE interface.]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends optional="true" config-file="plugin-withGit.xml">Git4Idea</depends>
<depends optional="true" config-file="plugin-withMaven.xml">org.jetbrains.idea.maven</depends>
    <depends optional="true" config-file="plugin-withSpring.xml">com.intellij.spring</depends>
    <depends optional="true" config-file="plugin-withTasks.xml">com.intellij.tasks</depends>
    <depends optional="true" config-file="plugin-withCoverage.xml">Coverage</depends>

    <resource-bundle>messages.WorkflowBundle</resource-bundle>

    <extensionPoints>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.tabProvider"
            interface="com.workflow.orchestrator.core.toolwindow.WorkflowTabProvider"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.branchNameAiGenerator"
            interface="com.workflow.orchestrator.core.ai.BranchNameAiGenerator"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.jiraTicketProvider"
            interface="com.workflow.orchestrator.core.workflow.JiraTicketProvider"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.textGenerationService"
            interface="com.workflow.orchestrator.core.ai.TextGenerationService"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.agentChatRedirect"
            interface="com.workflow.orchestrator.core.ai.AgentChatRedirect"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.sessionHistoryReader"
            interface="com.workflow.orchestrator.core.services.SessionHistoryReader"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.createPrLauncher"
            interface="com.workflow.orchestrator.core.bitbucket.CreatePrLauncher"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.openPrLister"
            interface="com.workflow.orchestrator.core.workflow.OpenPrLister"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.latestBuildLookup"
            interface="com.workflow.orchestrator.core.workflow.LatestBuildLookup"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.chainKeyResolver"
            interface="com.workflow.orchestrator.core.workflow.ChainKeyResolver"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.plugin.sonarProjectPickerLauncher"
            interface="com.workflow.orchestrator.core.services.SonarProjectPickerLauncher"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.authProvider"
            interface="com.workflow.orchestrator.core.auth.AuthProvider"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.workflowConfig"
            interface="com.workflow.orchestrator.core.config.WorkflowConfig"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.featureRegistry"
            interface="com.workflow.orchestrator.core.capability.FeatureRegistry"
            dynamic="true"/>
        <extensionPoint
            qualifiedName="com.workflow.orchestrator.agentToolContributor"
            interface="com.workflow.orchestrator.agent.tools.contribution.AgentToolContributor"
            dynamic="true"/>
    </extensionPoints>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Settings: Tools > Workflow Orchestrator > ... -->
        <projectConfigurable
            parentId="tools"
            instance="com.workflow.orchestrator.core.settings.WorkflowSettingsConfigurable"
            id="workflow.orchestrator"
            displayName="Workflow Orchestrator"
            nonDefaultProject="true"/>

        <projectConfigurable
            parentId="workflow.orchestrator"
            instance="com.workflow.orchestrator.core.settings.ConnectionsConfigurable"
            id="workflow.orchestrator.connections"
            displayName="Connections"
            nonDefaultProject="true"/>

        <projectConfigurable
            parentId="workflow.orchestrator"
            instance="com.workflow.orchestrator.core.settings.RepositoriesConfigurable"
            id="workflow.orchestrator.repositories"
            displayName="Repositories"
            nonDefaultProject="true"/>

        <projectConfigurable
            parentId="workflow.orchestrator"
            instance="com.workflow.orchestrator.jira.settings.JiraWorkflowConfigurable"
            id="workflow.orchestrator.jira_workflow"
            displayName="Jira &amp; Workflow"
            nonDefaultProject="true"/>

        <projectConfigurable
            parentId="workflow.orchestrator"
            instance="com.workflow.orchestrator.sonar.settings.CodeQualityConfigurable"
            id="workflow.orchestrator.code_quality"
            displayName="Code Quality"
            nonDefaultProject="true"/>

        <projectConfigurable
            parentId="workflow.orchestrator"
            instance="com.workflow.orchestrator.core.settings.TelemetryConfigurable"
            id="workflow.orchestrator.telemetry"
            displayName="Telemetry &amp; Logs"
            nonDefaultProject="true"/>

        <projectConfigurable
            parentId="workflow.orchestrator"
            instance="com.workflow.orchestrator.bamboo.settings.BuildsAndHealthChecksConfigurable"
            id="workflow.orchestrator.builds_health"
            displayName="Builds &amp; Health Checks"
            nonDefaultProject="true"/>

        <projectConfigurable
            parentId="workflow.orchestrator.agent"
            instance="com.workflow.orchestrator.core.settings.MultimodalSettingsConfigurable"
            id="workflow.orchestrator.agent.multimodal"
            displayName="Multimodal"
            nonDefaultProject="true"/>

        <projectConfigurable
            parentId="workflow.orchestrator.agent"
            instance="com.workflow.orchestrator.core.settings.CrossIdeDelegationConfigurable"
            id="com.workflow.orchestrator.core.settings.CrossIdeDelegationConfigurable"
            displayName="Cross-IDE Delegation"
            nonDefaultProject="true"/>

        <!-- :web module — bundled into this plugin (implementation(project(":web"))).
             Registered here rather than via a standalone web-plugin.xml descriptor so the
             platform treats it as part of this plugin, not a separate installable one. -->
        <projectService serviceInterface="com.workflow.orchestrator.core.web.WebFetchService"
                        serviceImplementation="com.workflow.orchestrator.web.service.WebFetchServiceImpl"/>
        <projectService serviceInterface="com.workflow.orchestrator.core.web.WebSearchService"
                        serviceImplementation="com.workflow.orchestrator.web.service.WebSearchServiceImpl"/>
        <projectConfigurable
            parentId="workflow.orchestrator.agent"
            instance="com.workflow.orchestrator.web.ui.WebSettingsConfigurable"
            id="com.workflow.orchestrator.web.settings"
            displayName="Web"
            nonDefaultProject="true"/>
        <postStartupActivity implementation="com.workflow.orchestrator.web.audit.WebAuditRotationStartup"/>

        <projectConfigurable
            parentId="workflow.orchestrator"
            instance="com.workflow.orchestrator.core.settings.HandoverConfigurable"
            id="workflow.orchestrator.handover"
            displayName="Handover"
            nonDefaultProject="true"/>

        <!-- Tool Window -->
        <toolWindow
            id="Workflow"
            anchor="bottom"
            icon="/icons/workflow.svg"
            factoryClass="com.workflow.orchestrator.core.toolwindow.WorkflowToolWindowFactory"/>

        <!-- Notification Groups -->
        <notificationGroup id="Workflow Commit AI" displayType="BALLOON"/>
        <notificationGroup id="workflow.build" displayType="BALLOON"/>
        <notificationGroup id="workflow.quality" displayType="BALLOON"/>
        <notificationGroup id="workflow.jira" displayType="BALLOON"/>
        <notificationGroup id="workflow.queue" displayType="BALLOON"/>
        <notificationGroup id="workflow.autodetect"
                           displayType="BALLOON"
                           isLogByDefault="false"/>

        <!-- Project Services -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.settings.PluginSettings"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.util.DefaultBranchResolver"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.settings.RepoContextResolver"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.notifications.WorkflowNotificationService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.onboarding.OnboardingService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.events.EventBus"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.workflow.WorkflowContextService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.ai.AiSettings"/>

        <!-- Unified Service Layer (shared by UI panels and AI agent) -->
        <projectService
            serviceInterface="com.workflow.orchestrator.core.services.JiraService"
            serviceImplementation="com.workflow.orchestrator.jira.service.JiraServiceImpl"/>
        <projectService
            serviceInterface="com.workflow.orchestrator.core.services.BambooService"
            serviceImplementation="com.workflow.orchestrator.bamboo.service.BambooServiceImpl"/>
        <projectService
            serviceInterface="com.workflow.orchestrator.core.services.SonarService"
            serviceImplementation="com.workflow.orchestrator.sonar.service.SonarServiceImpl"/>
        <projectService
            serviceInterface="com.workflow.orchestrator.core.services.BitbucketService"
            serviceImplementation="com.workflow.orchestrator.pullrequest.service.BitbucketServiceImpl"/>

        <!-- Maven Build Service -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.maven.MavenBuildService"/>

        <!-- Build/Import Problems Service (local IDE Maven/Gradle reload errors) -->
        <projectService
            serviceInterface="com.workflow.orchestrator.core.services.BuildProblemsService"
            serviceImplementation="com.workflow.orchestrator.core.services.impl.BuildProblemsServiceImpl"/>
        <projectService
            serviceInterface="com.workflow.orchestrator.core.services.BuildEventCaptureService"
            serviceImplementation="com.workflow.orchestrator.core.services.impl.BuildEventCaptureServiceImpl"/>
        <postStartupActivity
            implementation="com.workflow.orchestrator.core.services.impl.BuildEventCaptureProjectActivity"/>

        <!-- Chat link resolution (file:/class:/jira:/http(s):// hrefs from agent chat) -->
        <projectService
            serviceInterface="com.workflow.orchestrator.core.services.LinkResolver"
            serviceImplementation="com.workflow.orchestrator.core.services.impl.LinkResolverImpl"/>

        <!-- Health Check -->
        <vcsCheckinHandlerFactory
            implementation="com.workflow.orchestrator.core.healthcheck.HealthCheckCheckinHandlerFactory"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.healthcheck.HealthCheckService"/>
        <notificationGroup id="workflow.healthcheck" displayType="BALLOON"/>

        <!-- Jira Transition + Search Services -->
        <projectService
            serviceInterface="com.workflow.orchestrator.core.services.jira.TicketTransitionService"
            serviceImplementation="com.workflow.orchestrator.jira.service.TicketTransitionServiceImpl"/>
        <projectService
            serviceInterface="com.workflow.orchestrator.core.services.jira.JiraSearchService"
            serviceImplementation="com.workflow.orchestrator.jira.service.JiraSearchServiceImpl"/>
        <projectService
            serviceInterface="com.workflow.orchestrator.core.services.jira.TransitionDialogOpener"
            serviceImplementation="com.workflow.orchestrator.jira.ui.TransitionDialogOpenerImpl"/>

        <!-- Jira Active Ticket -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.jira.service.ActiveTicketService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.jira.service.TicketKeyCache"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.jira.service.IssueDetailCache"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.jira.service.DismissedBranchStore"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.jira.ui.TicketDetectionPresenter"/>

        <!-- Bamboo Services -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.bamboo.service.BuildMonitorService"/>

        <!-- Startup (onboarding check) -->
        <postStartupActivity
            implementation="com.workflow.orchestrator.core.onboarding.OnboardingStartupListener"/>
        <postStartupActivity
            implementation="com.workflow.orchestrator.core.settings.SettingsMigrationStartupActivity"/>

        <!-- Shareable plugin diagnostic log: small rotating file with ONLY this plugin's records -->
        <postStartupActivity
            implementation="com.workflow.orchestrator.core.diagnostics.PluginDiagnosticLogActivity"/>

        <!-- Auto-detect startup activity (runs after DumbService smart mode) -->
        <postStartupActivity
            implementation="com.workflow.orchestrator.core.autodetect.WorkflowAutoDetectStartupActivity"/>

        <postStartupActivity
            implementation="com.workflow.orchestrator.core.workflow.WorkflowContextProjectActivity"/>

        <!-- Bamboo→Bitbucket bridge (R-ADD-5, audit 2026-05-07): on a FAILED build,
             reverse-lookup the commit SHA to PRs and notify the user. -->
        <postStartupActivity
            implementation="com.workflow.orchestrator.bamboo.listeners.BuildFailureBridgeStartupActivity"/>

        <!-- TODO Phase 1B: BuildStatusBarWidgetFactory -->

        <!-- Auto-detect orchestrator (core, no module dependency) -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.autodetect.AutoDetectOrchestrator"/>

        <!-- SonarQube Project Services -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.sonar.service.SonarDataService"/>
        <projectService
            serviceInterface="com.workflow.orchestrator.core.services.SonarKeyDetectorService"
            serviceImplementation="com.workflow.orchestrator.sonar.service.SonarKeyDetector"/>
        <!-- SonarQube Editor Integration -->
        <codeInsight.lineMarkerProvider language="JAVA"
            implementationClass="com.workflow.orchestrator.sonar.ui.CoverageLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="kotlin"
            implementationClass="com.workflow.orchestrator.sonar.ui.CoverageLineMarkerProvider"/>

        <externalAnnotator language="JAVA"
            implementationClass="com.workflow.orchestrator.sonar.ui.SonarIssueAnnotator"/>
        <externalAnnotator language="kotlin"
            implementationClass="com.workflow.orchestrator.sonar.ui.SonarIssueAnnotator"/>

        <!-- Sonar Fix Intention Action (Alt+Enter) — language-filtered to Java/Kotlin only -->
        <intentionAction>
            <language>JAVA</language>
            <className>com.workflow.orchestrator.sonar.editor.SonarFixIntentionAction</className>
            <category>Workflow Orchestrator</category>
        </intentionAction>
        <intentionAction>
            <language>kotlin</language>
            <className>com.workflow.orchestrator.sonar.editor.SonarFixIntentionAction</className>
            <category>Workflow Orchestrator</category>
        </intentionAction>

        <!-- App-level (cross-project) -->
        <applicationService
            serviceImplementation="com.workflow.orchestrator.core.settings.ConnectionSettings"/>
        <applicationService
            serviceImplementation="com.workflow.orchestrator.core.network.NetworkStateService"/>
        <!-- B1: app-level lifecycle owner for AgentConfigLoader (survives project close) -->
        <applicationService
            serviceImplementation="com.workflow.orchestrator.agent.tools.subagent.AgentConfigLoaderLifecycle"/>

        <!-- Phase 2B: Handover Services -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.handover.service.HandoverStateService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.handover.service.CopyrightFixService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.handover.service.PreReviewService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.core.bitbucket.PrService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.handover.service.JiraClosureService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.handover.service.TimeTrackingService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.handover.service.HandoverAiSummaryCache"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.handover.service.HandoverPlaceholderResolver"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.handover.service.HandoverOverrideTracker"/>
        <postStartupActivity
            implementation="com.workflow.orchestrator.handover.service.HandoverOverrideTrackerActivity"/>

        <!-- Pull Request Services -->
        <projectService
            serviceImplementation="com.workflow.orchestrator.pullrequest.service.PrListService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.pullrequest.service.PrDetailService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.pullrequest.service.PrActionService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.pullrequest.service.PrReviewSessionRegistry"/>
        <projectService
            serviceInterface="com.workflow.orchestrator.core.prreview.PrReviewFindingsStore"
            serviceImplementation="com.workflow.orchestrator.core.prreview.PrReviewFindingsStoreImpl"/>

        <!-- Pull Request Notification Group -->
        <notificationGroup id="workflow.pr" displayType="BALLOON"/>

        <!-- Handover Notification Group -->
        <notificationGroup id="workflow.handover" displayType="BALLOON"/>

        <!-- Agent Module -->
        <notificationGroup id="workflow.agent" displayType="BALLOON"/>
        <!-- Agent security: hook file trust gate -->
        <notificationGroup id="Workflow Orchestrator Security" displayType="STICKY_BALLOON"/>
        <!-- Insights Module -->
        <notificationGroup id="workflow.insights" displayType="BALLOON"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.hooks.HookTrustStore"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.settings.AgentSettings"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.tools.background.BackgroundPool"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.monitor.MonitorPool"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.ui.AgentControllerRegistry"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.AgentService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.walkthrough.WalkthroughService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.delegation.DelegationInboundService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.delegation.DelegationOutboundService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.delegation.DelegationDoorbellService"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.settings.ToolPreferences"/>
        <projectService
            serviceInterface="com.workflow.orchestrator.core.web.SubagentSpawner"
            serviceImplementation="com.workflow.orchestrator.agent.subagent.SubagentSpawnerAdapter"/>
        <projectService
            serviceInterface="com.workflow.orchestrator.core.web.AgentToolRegistrationRefresher"
            serviceImplementation="com.workflow.orchestrator.agent.AgentToolRegistrationRefresherAdapter"/>
        <projectConfigurable
            parentId="workflow.orchestrator"
            instance="com.workflow.orchestrator.agent.settings.AgentParentConfigurable"
            id="workflow.orchestrator.agent"
            displayName="AI Agent"
            nonDefaultProject="true"/>
        <projectConfigurable
            parentId="workflow.orchestrator.agent"
            instance="com.workflow.orchestrator.agent.settings.AgentDatabaseProfilesConfigurable"
            id="workflow.orchestrator.agent.database_profiles"
            displayName="Database Profiles"
            nonDefaultProject="true"/>
        <projectConfigurable
            parentId="workflow.orchestrator.agent"
            instance="com.workflow.orchestrator.agent.settings.AgentProcessToolsConfigurable"
            id="workflow.orchestrator.agent.process_tools"
            displayName="Process Tools"
            nonDefaultProject="true"/>
        <projectConfigurable
            parentId="workflow.orchestrator.agent"
            instance="com.workflow.orchestrator.agent.settings.AgentAdvancedConfigurable"
            id="workflow.orchestrator.agent.advanced"
            displayName="Advanced"
            nonDefaultProject="true"/>
        <postStartupActivity
            implementation="com.workflow.orchestrator.agent.listeners.AgentStartupActivity"/>
        <postStartupActivity
            implementation="com.workflow.orchestrator.agent.delegation.DelegationDoorbellStartupActivity"/>
        <postStartupActivity
            implementation="com.workflow.orchestrator.agent.delegation.DelegationInboundStartupActivity"/>
        <postStartupActivity
            implementation="com.workflow.orchestrator.core.insights.WeeklyDigestStartupActivity"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.agent.tools.database.DatabaseSettings"/>
        <fileEditorProvider
            implementation="com.workflow.orchestrator.agent.ui.plan.AgentPlanEditorProvider"/>
        <fileEditorProvider
            implementation="com.workflow.orchestrator.agent.ui.AgentVisualizationEditorProvider"/>
        <fileEditorProvider
            implementation="com.workflow.orchestrator.agent.ui.AgentChatEditorProvider"/>
        <fileEditorProvider
            implementation="com.workflow.orchestrator.agent.testing.ToolTestingEditorProvider"/>
        <fileEditorProvider
            implementation="com.workflow.orchestrator.agent.ui.tooldocs.ToolDocsEditorProvider"/>
        <fileEditorProvider
            implementation="com.workflow.orchestrator.agent.ui.apidocs.ApiDocsEditorProvider"/>

        <!-- Commit Dialog: Jira Time Tracking -->
        <checkinHandlerFactory
            implementation="com.workflow.orchestrator.jira.vcs.TimeTrackingCheckinHandlerFactory"/>

        <!-- Post-Commit Jira Transition -->
        <checkinHandlerFactory
            implementation="com.workflow.orchestrator.jira.vcs.PostCommitTransitionHandlerFactory"/>

        <!-- Search Everywhere: Jira Tickets -->
        <searchEverywhereContributor
            implementation="com.workflow.orchestrator.jira.search.JiraSearchContributorFactory"/>

        <!-- Bamboo Run Configuration -->
        <configurationType implementation="com.workflow.orchestrator.bamboo.run.BambooBuildConfigurationType"/>

    </extensions>

    <extensions defaultExtensionNs="com.workflow.orchestrator">
        <authProvider
            implementation="com.workflow.orchestrator.core.auth.DefaultAuthProvider"/>
        <workflowConfig
            implementation="com.workflow.orchestrator.core.config.DefaultWorkflowConfig"/>
        <featureRegistry
            implementation="com.workflow.orchestrator.core.capability.DefaultFeatureRegistry"/>
        <branchNameAiGenerator
            implementation="com.workflow.orchestrator.core.ai.SourcegraphBranchNameGenerator"/>
        <jiraTicketProvider
            implementation="com.workflow.orchestrator.jira.service.JiraTicketProviderImpl"/>
        <textGenerationService
            implementation="com.workflow.orchestrator.core.ai.SourcegraphTextGenerationService"/>
        <agentChatRedirect
            implementation="com.workflow.orchestrator.agent.ui.AgentChatRedirectImpl"/>
        <tabProvider implementation="com.workflow.orchestrator.jira.ui.SprintTabProvider"/>
        <tabProvider implementation="com.workflow.orchestrator.bamboo.ui.BuildTabProvider"/>
        <tabProvider implementation="com.workflow.orchestrator.sonar.ui.QualityTabProvider"/>
        <tabProvider implementation="com.workflow.orchestrator.pullrequest.ui.PrTabProvider"/>
        <tabProvider implementation="com.workflow.orchestrator.handover.ui.HandoverTabProvider"/>
        <tabProvider implementation="com.workflow.orchestrator.agent.ui.AgentTabProvider"/>
        <tabProvider implementation="com.workflow.orchestrator.core.toolwindow.insights.InsightsTabProvider"/>
        <sessionHistoryReader implementation="com.workflow.orchestrator.agent.insights.AgentSessionHistoryReader"/>
        <createPrLauncher implementation="com.workflow.orchestrator.pullrequest.action.CreatePrLauncherImpl"/>
        <openPrLister implementation="com.workflow.orchestrator.pullrequest.workflow.OpenPrListerImpl"/>
        <latestBuildLookup implementation="com.workflow.orchestrator.bamboo.workflow.LatestBuildLookupImpl"/>
        <chainKeyResolver implementation="com.workflow.orchestrator.bamboo.workflow.ChainKeyResolverImpl"/>
        <sonarProjectPickerLauncher
            implementation="com.workflow.orchestrator.sonar.service.SonarProjectPickerLauncherImpl"/>
    </extensions>

    <applicationListeners>
        <listener class="com.workflow.orchestrator.core.autodetect.AutoDetectFileListener"
                  topic="com.intellij.openapi.vfs.newvfs.BulkFileListener"/>
        <listener class="com.workflow.orchestrator.core.http.HttpResourceCleanupListener"
                  topic="com.intellij.ide.plugins.DynamicPluginListener"/>
    </applicationListeners>

    <actions>
        <action
            id="Workflow.GenerateCommitMessage"
            text="Generate with Workflow"
            description="Generate commit message using AI"
            class="com.workflow.orchestrator.core.vcs.GenerateCommitMessageAction">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="first"/>
        </action>
        <action
            id="Workflow.OpenToolTesting"
            text="Agent Tool Testing"
            description="Open interactive agent tool testing harness"
            class="com.workflow.orchestrator.agent.testing.OpenToolTestingAction">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action
            id="Workflow.ViewToolDocumentation"
            text="View Tool Documentation"
            description="Browse rich per-tool documentation for documented agent tools"
            class="com.workflow.orchestrator.agent.ui.tooldocs.OpenToolDocsAction">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action
            id="Workflow.ViewApiDocumentation"
            text="View API Documentation"
            description="Browse documented external API endpoints (Jira, Bitbucket, Bamboo, SonarQube, Sourcegraph)"
            class="com.workflow.orchestrator.agent.ui.apidocs.OpenApiDocsAction">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action
            id="Workflow.GenerateInsightsReport"
            text="Generate Insights Report"
            description="Generate an AI-powered insights HTML report for recent agent sessions"
            class="com.workflow.orchestrator.core.insights.GenerateReportAction">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
