<idea-plugin>
    <!-- Registered only when the Coverage plugin is present (optional dependency). -->

    <extensions defaultExtensionNs="com.intellij">
        <coverageRunner
            implementation="com.workflow.orchestrator.sonar.coverage.SonarCoverageRunner"/>
        <coverageEngine
            implementation="com.workflow.orchestrator.sonar.coverage.SonarCoverageEngine"/>
        <projectService
            serviceImplementation="com.workflow.orchestrator.sonar.coverage.SonarCoverageAnnotator"/>
    </extensions>
</idea-plugin>
