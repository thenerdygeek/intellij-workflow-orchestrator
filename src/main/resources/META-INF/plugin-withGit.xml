<!--
  Extensions registered only when Git4Idea is available.
  Referenced from plugin.xml via: <depends optional="true" config-file="plugin-withGit.xml">Git4Idea</depends>
-->
<idea-plugin>
    <extensions defaultExtensionNs="com.intellij">
        <!-- Eagerly wire TicketDetectionPresenter so its EventBus subscription
             is active when BranchChangeTicketDetector emits events. -->
        <postStartupActivity
            implementation="com.workflow.orchestrator.jira.listeners.TicketDetectionStartupActivity"/>
    </extensions>

    <projectListeners>
        <listener class="com.workflow.orchestrator.jira.listeners.BranchChangeTicketDetector"
                  topic="com.intellij.openapi.vcs.BranchChangeListener"/>
        <listener class="com.workflow.orchestrator.core.events.BranchChangedEventEmitter"
                  topic="com.intellij.openapi.vcs.BranchChangeListener"/>
    </projectListeners>
</idea-plugin>
